{
  "name": "n8n-nodes-snapsharp",
  "version": "1.0.0",
  "description": "n8n community node for SnapSharp Screenshot & OG Image API",
  "keywords": [
    "n8n-community-node-package",
    "snapsharp",
    "screenshot",
    "og-image",
    "automation"
  ],
  "license": "MIT",
  "homepage": "https://snapsharp.dev",
  "repository": {
    "type": "git",
    "url": "https://github.com/bogdanov-igor/snapsharp-sdk"
  },
  "main": "index.js",
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "prepublishOnly": "npm run build"
  },
  "files": [
    "dist"
  ],
  "n8n": {
    "n8nNodesApiVersion": 1,
    "credentials": [
      "dist/credentials/SnapSharpApi.credentials.js"
    ],
    "nodes": [
      "dist/nodes/SnapSharp/SnapSharp.node.js"
    ]
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "n8n-workflow": "^1.0.0",
    "typescript": "^5.0.0"
  },
  "peerDependencies": {
    "n8n-workflow": "^1.0.0"
  }
}
